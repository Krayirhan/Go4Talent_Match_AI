# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
# (service role key'i Supabase → Settings → API → service_role'den al)

# Port (Render otomatik 10000 verir)
PORT=5001

# CORS — virgülle ayır, boşluk olmadan
ALLOWED_ORIGINS=http://localhost:5000,https://your-frontend.onrender.com

# ML Servisi URL'si
ML_SERVICE_URL=http://localhost:5002
